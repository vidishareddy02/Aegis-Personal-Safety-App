<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRESSED (RED) -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#E53935"/>
        </shape>
    </item>

    <!-- DEFAULT (PURPLE) -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#7B61FF"
                android:endColor="#5E35B1"
                android:angle="45"/>
        </shape>
    </item>

</selector>