<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#EEE9FF">

        <!-- TITLE -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aegis"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:letterSpacing="0.05"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your personal safety companion"
            android:textSize="16sp"
            android:textColor="#718096"
            android:layout_marginBottom="40dp"/>

        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <!-- Circle background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.4"/>

            <!-- Logo -->
            <ImageView
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:src="@drawable/aegis_logo"
                android:scaleType="centerCrop"/>
        </FrameLayout>
        <!-- CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/rounded_card"
            android:elevation="8dp"
            android:layout_marginTop="10dp">

            <EditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Name"
                android:background="@drawable/input_background"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:textColor="#2D3748"
                android:textColorHint="#A0AEC0"/>

            <EditText
                android:id="@+id/phoneInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Phone Number"
                android:background="@drawable/input_background"
                android:textColor="#2D3748"
                android:textColorHint="#A0AEC0"
                android:inputType="phone"
                android:padding="14dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/contact1Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Emergency Contact 1"
                android:background="@drawable/input_background"
                android:textColor="#2D3748"
                android:textColorHint="#A0AEC0"
                android:inputType="phone"
                android:padding="14dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/contact2Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Emergency Contact 2"
                android:background="@drawable/input_background"
                android:textColor="#2D3748"
                android:textColorHint="#A0AEC0"
                android:inputType="phone"
                android:padding="14dp"/>
        </LinearLayout>

        <!-- BUTTON -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Continue"
            android:id="@+id/continueBtn"
            android:textAllCaps="false"
            android:layout_marginTop="50dp"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="16dp"
            android:background="@drawable/rounded_button"/>

    </LinearLayout>

</ScrollView>