<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:clickable="true"
    android:focusable="true"
    android:onClick="handleScreenTap">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aegis"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#5A3EC8"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ Are you safe?"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We detected unusual activity"
            android:textSize="16sp"
            android:textColor="#777"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnSOSNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SEND SOS NOW"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@android:color/holo_red_dark"
            android:layout_marginTop="16dp"
            android:padding="12dp"/>

        <!-- 🔵 COUNTDOWN AREA -->
        <FrameLayout
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center">

            <!-- OUTER GLOW -->
            <View
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:background="@drawable/glow_circle"
                android:alpha="0.25"/>

            <!-- INNER GLOW -->
            <View
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:background="@drawable/glow_circle"
                android:alpha="0.15"/>

            <!-- MAIN CIRCLE -->
            <TextView
                android:id="@+id/countdownText"
                android:layout_width="170dp"
                android:layout_height="170dp"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="10"
                android:textSize="52sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/sos_circle"/>


        </FrameLayout>

        <!-- 🔴 ALERT TEXT -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sending alert..."
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"/>

        <!-- ⚠️ RISK CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginTop="24dp"
            android:elevation="8dp"
            android:lineSpacingExtra="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ Risk Detected"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#E65100"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/riskText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="15sp"
                android:textColor="#E65100"
                android:layout_marginBottom="4dp"/>
        </LinearLayout>

        <!-- INSTRUCTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap anywhere to cancel alert"
            android:textSize="14sp"
            android:textColor="#777"
            android:gravity="center"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</FrameLayout>