<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6F3FF">

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="0dp">

            <!-- TITLE -->
            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚨 EMERGENCY ACTIVE"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notifying your emergency contacts"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#777"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp"/>

            <!-- SOS ACTIVE CIRCLE -->
            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="20dp">

                <!-- GLOW -->
                <View
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:background="@drawable/glow_circle"
                    android:alpha="0.4"/>

                <!-- RED CIRCLE -->
                <TextView
                    android:id="@+id/sosCircle"
                    android:layout_width="170dp"
                    android:layout_height="170dp"
                    android:layout_gravity="center"
                    android:elevation="8dp"
                    android:gravity="center"
                    android:text="SOS ACTIVE"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:alpha="0.9"
                    android:background="@drawable/sos_circle_red"/>

            </FrameLayout>

            <!-- LIVE ACTION CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginTop="20dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Live Actions"
                    android:textStyle="bold"
                    android:textColor="#5A3EC8"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Sharing live location"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📞 Calling emergency contact"
                    android:textColor="#2D3748"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💬 Alert message sent"
                    android:textColor="#2D3748"/>
            </LinearLayout>

            <!-- CANCEL BUTTON -->
            <Button
                android:id="@+id/cancelBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Cancel SOS"
                android:textColor="#FFFFFF"
                android:background="@drawable/sos_circle"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_bg"
        app:menu="@menu/bottom_menu"/>

</LinearLayout>